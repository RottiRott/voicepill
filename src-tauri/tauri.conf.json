{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "VoicePill",
  "version": "0.1.0",
  "identifier": "de.dachrinnecheck.voicepill",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "VoicePill",
        "url": "index.html",
        "width": 620,
        "height": 760,
        "minWidth": 520,
        "minHeight": 600,
        "visible": true,
        "center": true
      },
      {
        "label": "pill",
        "title": "VoicePill Status",
        "url": "pill.html",
        "width": 700,
        "height": 52,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "focus": false,
        "visibleOnAllWorkspaces": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
